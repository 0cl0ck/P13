{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Conversations (chat) – MongoDB collection validator",
  "description": "Schema for chat conversations between a customer and an agent.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "conversation_id": { "type": "string", "pattern": "^[a-fA-F0-9]{24}$" },
    "customer_id": { "type": "integer", "minimum": 1 },
    "agent_id": { "type": ["integer", "null"], "minimum": 1 },
    "created_at": { "type": "string", "format": "date-time" },
    "messages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "message_id": { "type": "string", "pattern": "^[a-fA-F0-9]{24}$" },
          "sender": { "type": "string", "enum": ["customer", "agent"] },
          "timestamp": { "type": "string", "format": "date-time" },
          "content": { "type": "string", "minLength": 1, "maxLength": 4000 }
        },
        "required": ["sender", "timestamp", "content"]
      }
    }
  },
  "required": ["conversation_id", "customer_id", "messages"]
}
